  <script src="icons.js"></script>

  <script>
    (function () {
      var bildSmall  = document.getElementById('bild-small');
      var bildPanel  = document.getElementById('bild-panel');
      var zuButton   = document.getElementById('zu-button');
      var weiterLink = document.getElementById('weiter-link');

      bildPanel.style.display  = 'none';
      weiterLink.style.display = 'none';
      weiterLink.setAttribute('tabindex', '-1');
      weiterLink.setAttribute('aria-hidden', 'true');

      function openBild() {
        bildSmall.style.display = 'none';
        bildPanel.style.display = '';
        bildPanel.setAttribute('aria-hidden', 'false');
        zuButton.focus();
      }

      function closeBild() {
        bildPanel.style.display  = 'none';
        bildPanel.setAttribute('aria-hidden', 'true');
        bildSmall.style.display  = '';
        weiterLink.style.display = '';
        weiterLink.setAttribute('tabindex', '0');
        weiterLink.setAttribute('aria-hidden', 'false');
        weiterLink.focus();
      }

      bildSmall.addEventListener('click', openBild);
      bildSmall.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openBild(); }
      });
      zuButton.addEventListener('click', closeBild);
      zuButton.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); closeBild(); }
      });
    }());
  </script>

